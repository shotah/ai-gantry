# Personal-assistant example — copy to .env and fill secrets.
# Compose maps GEMINI_* → gantry LLM_* (see compose.yml).

# --- Timezone (cron + "what time is it") -------------------------------------
TZ=America/Los_Angeles

# --- Gemini (required for default chat) --------------------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Or set all three to swap chat providers (xAI / Ollama / …):
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_API_KEY=
# LLM_MODEL=grok-4

# --- Channel -----------------------------------------------------------------
# telegram (default) or stdio (docker compose run --rm -it gantry)
CHANNEL=telegram

# Required when CHANNEL=telegram — allowlist only, no pairing
# @BotFather → token; @userinfobot → numeric id
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# --- Optional gantry knobs ---------------------------------------------------
# STREAM_REPLIES=false
# LOG_LEVEL=info
# MEMORY_ENABLED=true
# CRON_ENABLED=true
# TOOL_SCHEMA_MAX_TOKENS=0
