# Personal-assistant example — copy to .env and fill secrets.
# Compose maps GEMINI_* → gantry LLM_* (see compose.yml).

# --- Timezone (cron + "what time is it") -------------------------------------
TZ=America/Los_Angeles

# --- Gemini (required for default chat) --------------------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Or set all three to swap chat providers (xAI / Ollama / …):
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_API_KEY=
# LLM_MODEL=grok-4

# --- Channel -----------------------------------------------------------------
# telegram (default), discord, slack, or stdio (docker compose run --rm -it gantry)
CHANNEL=telegram

# Required when CHANNEL=telegram — allowlist only, no pairing
# @BotFather → token; @userinfobot → numeric id
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Required when CHANNEL=discord — docs/discord.md (Message Content Intent on)
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=

# Required when CHANNEL=slack — docs/slack.md (Socket Mode)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USERS=

# --- Optional gantry knobs ---------------------------------------------------
# LLM_MAX_TOKENS=1024           # completion cap (0 = provider default)
# STREAM_REPLIES=false
# LOG_LEVEL=info
# MEMORY_ENABLED=true
# CRON_ENABLED=true
# TOOL_SCHEMA_MAX_TOKENS=0
