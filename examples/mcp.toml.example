# MCP server manifest — listed = granted (process may start).
# Mount at MCP_MANIFEST (default /etc/gantry/mcp.toml).
#
# Tool names reach the model as {tools_prefix or name}__{tool}.
#
# Optional publishing filters (host-side, after tools/list):
#   tools   = ["get_sleep", "get_weight"]   # allowlist (omit = all)
#   exclude = ["raw_*"]                     # denylist (shell-style * ?)
#   tools_prefix = "garm"                   # override name used in {prefix}__{tool}

# [[server]]
# name    = "example"
# command = "example-mcp"
# args    = ["--flag", "value"]

# Example shape used by a full personal-assistant image (binaries must exist
# on PATH inside the container):
#
# [[server]]
# name    = "google-workspace"
# command = "google-workspace-mcp-go"
# args    = [
#   "--tools",
#   "gmail drive calendar docs sheets tasks contacts",
#   "--tool-tier",
#   "core",
# ]
#
# [[server]]
# name    = "garmin"
# command = "garmin"
# args    = ["mcp"]
# tools   = ["get_sleep", "get_weight", "get_hrv"]
# # exclude = ["raw_*"]
#
# [[server]]
# name    = "strava"
# command = "strava-mcp"
