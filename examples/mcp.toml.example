# MCP server manifest — listed = granted (process may start).
# Mount at MCP_MANIFEST (default /etc/gantry/mcp.toml).
#
# Tool names reach the model as {tools_prefix or name}__{tool}.
#
# Optional publishing filters (host-side, after tools/list):
#   tools   = ["get_sleep", "get_weight"]   # allowlist (omit = all)
#   exclude = ["raw_*"]                     # denylist (shell-style * ?)
#   tools_prefix = "garm"                   # override name used in {prefix}__{tool}
#
# Full appliance-style compose + commented servers:
#   examples/personal-assistant/
# Production image with binaries baked in:
#   https://github.com/shotah/docker_open_claw

# [[server]]
# name    = "example"
# command = "example-mcp"
# args    = ["--flag", "value"]

# --- Shape used by LOCAL_AGENT (binaries must exist on PATH) -------------------------
#
# [[server]]
# name    = "google-workspace"
# command = "google-workspace-mcp-go"
# args    = [
#   "--tools",
#   "gmail drive calendar docs sheets tasks contacts",
#   "--tool-tier",
#   "core",
# ]
#
# [[server]]
# name    = "strava"
# command = "strava-mcp"
#
# [[server]]
# name    = "garmin"
# command = "garmin"
# args    = ["mcp", "--tool-tier", "core"]
#
# [[server]]
# name    = "google-search"
# command = "mcp-gemini-google-search"
#
# [[server]]
# name    = "cast"
# command = "mcp-beam"
#
# [[server]]
# name    = "ytmusic"
# command = "youtube-go-mcp"
