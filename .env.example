# Required — OpenAI-compatible endpoint (Gemini, xAI, Ollama, …)
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-3.5-flash

# Channel: telegram (default) or stdio (local REPL)
CHANNEL=telegram

# Required when CHANNEL=telegram — allowlist only, no pairing
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Optional
# PERSONA_DIR=/persona
# DATA_DIR=/data
# MCP_MANIFEST=/etc/gantry/mcp.toml
# HISTORY_MAX_MESSAGES=200
# HISTORY_MAX_TOKENS=128000
# TOOL_RESULT_MAX_CHARS=16000
# TOOL_MAX_ITERATIONS=20
# MEMORY_ENABLED=true
# MEMORY_BACKEND=builtin
# MEMORY_CONSOLIDATE_MINUTES=30
# LOG_LEVEL=info
