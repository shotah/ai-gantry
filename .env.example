# Required — OpenAI-compatible endpoint (Gemini, xAI, Ollama, …)
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-3.5-flash
# LLM_MAX_TOKENS=1024             # completion cap (0 = provider default)
# Tip: LOCAL_AGENT compose maps GEMINI_API_KEY → LLM_API_KEY for you.
# See examples/personal-assistant/.env.example

# Channel: telegram (default), discord, slack, or stdio (local REPL)
CHANNEL=telegram

# Required when CHANNEL=telegram — allowlist only, no pairing
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Required when CHANNEL=discord — snowflake user IDs (see docs/discord.md)
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=

# Required when CHANNEL=slack — Socket Mode (see docs/slack.md)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USERS=

# Optional
# PERSONA_DIR=/persona
# DATA_DIR=/data
# MCP_MANIFEST=/etc/gantry/mcp.toml
# HISTORY_MAX_MESSAGES=200
# HISTORY_MAX_TOKENS=128000
# TOOL_RESULT_MAX_CHARS=16000
# TOOL_MAX_ITERATIONS=20
# TOOL_SCHEMA_MAX_TOKENS=0
# MEMORY_ENABLED=true
# MEMORY_BACKEND=builtin
# MEMORY_CONSOLIDATE_MINUTES=30
# CRON_ENABLED=true
# CRON_TZ=UTC
# CRON_MAX_JOBS=50
# CRON_TICK_SECONDS=15
# STREAM_REPLIES=false
# LOG_LEVEL=info
